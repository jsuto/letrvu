# Listen address for the HTTP server (default :8080)
LISTEN_ADDR=:8080

# Database driver: "sqlite" (default, single file) or "postgres"
DB_DRIVER=sqlite

# SQLite: path to the database file
DATABASE_URL=./letrvu.db

# PostgreSQL: connection string
# DATABASE_URL=postgres://user:password@localhost:5432/letrvu

# Session encryption secret — 32 random bytes, hex-encoded.
# Generate with: openssl rand -hex 32
# If unset, an ephemeral secret is generated (sessions lost on restart).
SESSION_SECRET=

# Optional: pre-fill the login form with server defaults.
# Users still enter their own username and password.
IMAP_HOST=
IMAP_PORT=993
SMTP_HOST=
SMTP_PORT=587

# Set to false on servers with a valid public CA certificate
IMAP_INSECURE_TLS=true

# Set to true when serving over HTTPS. Adds the Secure flag to session and
# CSRF cookies so they are never sent over plain HTTP.
SECURE_COOKIES=false

# How long to cache IMAP folder unseen counts before re-fetching.
# Uses Go duration syntax: 30s, 2m, 5m, etc. Default: 2m
FOLDER_CACHE_TTL=2m
