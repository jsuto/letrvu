# Listen address for the HTTP server (default :8080)
LISTEN_ADDR=:8080

# Database driver: "sqlite" (default, single file) or "postgres"
DB_DRIVER=sqlite

# SQLite: path to the database file
DATABASE_URL=./letrvu.db

# PostgreSQL: connection string
# DATABASE_URL=postgres://user:password@localhost:5432/letrvu

# Session encryption secret — 32 random bytes, hex-encoded.
# Generate with: openssl rand -hex 32
# If unset, an ephemeral secret is generated (sessions lost on restart).
SESSION_SECRET=

# Optional: pre-fill the login form with server defaults.
# Users still enter their own username and password.
IMAP_HOST=
IMAP_PORT=993
SMTP_HOST=
SMTP_PORT=587

# Set to false on servers with a valid public CA certificate
IMAP_INSECURE_TLS=true

# Hostname used in the right-hand side of generated Message-IDs, e.g.:
#   <1748123456789012345.a3f8c2d1@webmail.example.com>
# Set to the public hostname of your webmail server.
# Defaults to "localhost" if unset.
WEBMAIL_HOSTNAME=

# Set to true when serving over HTTPS. Adds the Secure flag to session and
# CSRF cookies so they are never sent over plain HTTP.
SECURE_COOKIES=false

# IP address or CIDR of your reverse proxy (nginx, Caddy, etc.).
# When set, X-Forwarded-For / X-Real-IP are trusted only for connections that
# arrive from this address, giving correct client IP in audit logs.
# A plain IP is treated as /32 (IPv4) or /128 (IPv6).
# Leave empty when running without a reverse proxy.
# Examples:
#   TRUSTED_PROXY=127.0.0.1        (proxy on the same host)
#   TRUSTED_PROXY=10.0.0.5         (proxy on a private network)
#   TRUSTED_PROXY=10.0.0.0/8       (any proxy in a private subnet)
TRUSTED_PROXY=

# How long to cache IMAP folder unseen counts before re-fetching.
# Uses Go duration syntax: 30s, 2m, 5m, etc. Default: 2m
FOLDER_CACHE_TTL=2m

# Log verbosity: "info" (default) or "debug".
# debug enables detailed logs for auth header parsing, etc.
LOG_LEVEL=info

# Comma-separated list of your organisation's mail domains.
# When set, messages from senders outside these domains are flagged "External"
# in the message view — but only when Authentication-Results headers are
# present, so the check is based on authenticated data rather than the
# spoofable From: header.
# Example: INTERNAL_DOMAINS=example.com,subsidiary.example.com
INTERNAL_DOMAINS=

# Brute force login protection.
# An IP is locked for LOGIN_LOCKOUT after LOGIN_MAX_ATTEMPTS failures within LOGIN_WINDOW.
# Uses Go duration syntax: 30s, 1m, 15m, etc.
LOGIN_MAX_ATTEMPTS=5
LOGIN_WINDOW=1m
LOGIN_LOCKOUT=15m
